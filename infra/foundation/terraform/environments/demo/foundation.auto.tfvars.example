resource_group_name = "rg-clickops-gitops-foundation-demo"
location            = "canadacentral"

# Enable only what you are actively demoing:
enable_network_hub       = false
enable_storage_fileshare = false
enable_keyvault          = false
enable_identity_entra    = false
enable_adm_agent         = false
enable_compute_gallery   = true
enable_artifact_storage  = true

artifact_storage_account_name             = "stclickopsdemoimg"
artifact_storage_container_name           = "ctxsw"
artifact_storage_account_tier             = "Standard"
artifact_storage_account_replication_type = "LRS"
artifact_storage_access_tier              = "Hot"

compute_gallery_name        = "cgclickopsdemo"
compute_gallery_description = "Compute Gallery for Citrix base images"

compute_gallery_image_definitions = {
  "ws2022-cvad-apps" = {
    os_type   = "Windows"
    publisher = "Ferroque"
    offer     = "windows-server"
    sku       = "ws2022-cvad-apps"
  }
  "win11-25h2-cvad" = {
    os_type   = "Windows"
    publisher = "Ferroque"
    offer     = "windows-11"
    sku       = "win11-25h2-cvad"
  }
}

compute_gallery_tags = {
  Environment = "demo"
  Purpose     = "citrix-image-gallery"
}

artifact_storage_tags = {
  Environment = "demo"
  Purpose     = "citrix-image-artifacts"
}
