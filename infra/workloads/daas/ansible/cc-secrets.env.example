export CC_LOCAL_ADMIN_PASSWORD='REPLACE_WITH_CLOUD_CONNECTOR_LOCAL_ADMIN_PASSWORD'
export CC_DOMAIN_JOIN_PASSWORD='REPLACE_WITH_CLICKOPS_LOCALADMIN_PASSWORD'

# Optional. If unset, the role will skip domain join.
export CC_DOMAIN_JOIN_ENABLED='true'

# Optional. If unset, the installer role skips Cloud Connector installation.
export CC_INSTALLER_URL='https://example.invalid/CitrixCloudConnector.exe'
export CC_INSTALLER_ARGUMENTS='/q /ParametersFilePath:C:\Temp\CitrixCloudConnector\cwc.json'

# Preferred. Separate values used to generate cwc.json automatically.
export CC_CUSTOMER_ID='REPLACE_WITH_CITRIX_CLOUD_CUSTOMER_ID'
export CC_CLIENT_ID='REPLACE_WITH_SECURE_PRINCIPAL_ID'
export CC_CLIENT_SECRET='REPLACE_WITH_SECURE_PRINCIPAL_SECRET'
export CC_RESOURCE_LOCATION_ID='REPLACE_WITH_RESOURCE_LOCATION_ID'

# Optional fallback. Raw JSON content to drop on the server as cwc.json instead
# of generating it from the values above.
# export CC_CWC_JSON_CONTENT='{"customerName":"...","clientId":"...","clientSecret":"...","resourceLocationId":"...","acceptTermsOfService":"true"}'
