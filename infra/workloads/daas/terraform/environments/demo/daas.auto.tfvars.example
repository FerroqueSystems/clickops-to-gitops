subscription_id           = "0cb554f1-e4b4-4246-8604-b050e5dec014"
environment_name          = "demo"
catalog_generation        = "2026-03"
compute_gallery_name      = "cgclickopsdemo"
shared_resource_group_name = "rg-clickops-gitops-demo"
# Citrix MCS should place catalog-created VDAs and related Azure artifacts in a
# dedicated resource group instead of the shared platform resource group.
# Terraform will grant the Cloud Connector managed identities Contributor on
# this resource group automatically.
machine_catalog_resource_group_name = "rg-clickops-gitops-demo-catalogs"
shared_virtual_network_name = "terraform-virtual-network"
management_subnet_name    = "terraform-management-subnet"
server_subnet_name        = "terraform-server-subnet"
client_subnet_name        = "terraform-client-subnet"

resource_location_name    = "demo-canadacentral"
# If you do not have rights to create a Citrix resource location, set these
# instead and Terraform will use the existing one.
# existing_resource_location_id   = "replace-with-citrix-resource-location-id"
# existing_resource_location_name = "demo-canadacentral"
hosting_connection_name   = "demo-canadacentral-shared"
hosting_connection_authentication_mode = "SystemAssignedManagedIdentity"
# Keep the hosting unit narrow for MCS. Cloud Connectors are static Azure VMs
# and do not need the management subnet exposed through the Citrix hosting unit.
hosting_connection_subnet_roles = ["server"]
citrix_cloud_environment  = "Production"

cloud_connector_count      = 2
cloud_connector_name_prefix = "ctx-cc"
cloud_connector_vm_size    = "Standard_D4s_v5"
cloud_connector_subnet_role = "management"
cloud_connector_enable_system_assigned_identity = true
cloud_connector_admin_username = "localadmin"
cloud_connector_private_ip_addresses = [
  "10.45.1.30",
  "10.45.1.31",
]
cloud_connector_enable_domain_join   = true
cloud_connector_domain_name          = "clickops.demo"
cloud_connector_domain_join_username = "CLICKOPS\\localadmin"
# Preferred for machine catalogs: create or import a Citrix service account in
# Web Studio and set its ID here so MCS uses the stored credential instead of an
# inline password during catalog creation.
# machine_catalog_domain_service_account_id = "replace-with-citrix-service-account-id"
cloud_connector_auto_shutdown_enabled = true
cloud_connector_auto_shutdown_time    = "1800"
cloud_connector_auto_shutdown_timezone = "Eastern Standard Time"

machine_catalogs = {
  win11-pooled = {
    subnet_role           = "server"
    session_type          = "single_session"
    image_definition_name = "win11-25h2-cvad"
    image_version         = "1.0.0"
    machine_count         = 10
    vm_size               = "Standard_D4s_v5"
    delivery_group_name   = "dg-win11-pooled"
  }
  ws2022-apps = {
    subnet_role           = "server"
    session_type          = "multi_session"
    image_definition_name = "ws2022-cvad-apps"
    image_version         = "1.0.0"
    machine_count         = 6
    vm_size               = "Standard_D8s_v5"
    delivery_group_name   = "dg-published-apps"
  }
}

tags = {
  Environment = "demo"
  Purpose     = "citrix-daas-monthly-rebuild"
  Lifecycle   = "mixed"
}

# Review the current management and server subnet NSGs before deploying Cloud Connectors or VDAs.
# Catalog VMs stay on the same VNet/subnet even when they are created in a
# different Azure resource group. Resource groups are management boundaries, not
# network boundaries.
# Secrets are provided via environment variables or GitHub Secrets:
# TF_VAR_cloud_connector_admin_password
# TF_VAR_cloud_connector_domain_join_password
# TF_VAR_citrix_customer_id
# TF_VAR_citrix_client_id
# TF_VAR_citrix_client_secret
# If you switch hosting_connection_authentication_mode to AppClientSecret:
# TF_VAR_hosting_connection_application_id
# TF_VAR_hosting_connection_application_secret
