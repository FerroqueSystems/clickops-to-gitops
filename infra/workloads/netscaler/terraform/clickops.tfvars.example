# NetScaler Console Agent
enable_netscaler_agent              = false
netscaler_agent_name                = "terraform-netscaler-agent"
netscaler_agent_admin_username      = "agentadmin"
netscaler_agent_vm_size             = "Standard_D2s_v3"
netscaler_agent_image_offer         = null
netscaler_agent_image_sku           = null
netscaler_agent_image_version       = "latest"
netscaler_agent_auto_register       = true
# Set the exact marketplace offer/sku for NetScaler Console Agent in your subscription/region.
# Do not use nsroot or nsrecover as netscaler_agent_admin_username.
# TF_VAR_netscaler_agent_admin_password
# TF_VAR_netscaler_console_service_url
# TF_VAR_netscaler_console_activation_code

virtual_network_address_space         = "10.45.0.0/16"
management_subnet_address_prefix      = "10.45.1.0/24"
client_subnet_address_prefix          = "10.45.2.0/24"
server_subnet_address_prefix          = "10.45.3.0/24"
location                              = "eastus2"

controlling_subnet                    = "10.10.10.0/24"
resource_group_name                   = "rg-clickops-gitops-demo"

# Secrets are provided via environment variables or GitHub Secrets:
# TF_VAR_citrixadc_rpc_node_password
# TF_VAR_adc_admin_password
